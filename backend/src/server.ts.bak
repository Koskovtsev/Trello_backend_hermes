import express from 'express';
import type { Request, Response, NextFunction } from 'express';
import { PrismaClient } from '@prisma/client';
import cors from 'cors';
import dotenv from 'dotenv';

dotenv.config();

export const app = express();
const port = process.env.PORT || 3001;

app.use(cors());
app.use(express.json());

const prisma = new PrismaClient({
  datasources: {
    db: {
      url: "file:/mnt/i/AI/Trello_backend/backend/src/prisma/dev.db"
    }
  }
});

const authenticate = (req: Request, res: Response, next: NextFunction) => {
  if (req.path === '/login' || req.path.startsWith('/user')) return next();
  const authHeader = req.headers.authorization;
  if (authHeader === 'Bearer 123' || (authHeader && authHeader.startsWith('Bearer '))) {
    return next();
  }
  res.status(401).json({ error: 'Unauthorized' });
};

const ensureJsonString = (val: any): string | null => {
  if (!val) return null;
  if (typeof val === 'string') {
    try {
      JSON.parse(val);
      return val;
    } catch {
      return JSON.stringify(val);
    }
  }
  return JSON.stringify(val);
};

const ensureJsonObject = (val: any) => {
  if (!val) return {};
  if (typeof val === 'object') {
    return val;
  }
  try {
    const parsed = JSON.parse(val);
    if (typeof parsed === 'string') {
      return JSON.parse(parsed);
    }
    return parsed;
  } catch (e) {
    return {};
  }
};

app.use(authenticate);

const getParam = (param: any): any => {
    if (Array.isArray(param)) return param[0];
    return param !== undefined && param !== null ? param : '';
};

app.post('/user/', async (req: Request, res: Response) => {
  try {
    const { email } = req.body as { email: string };
    if (!email) {
      res.status(400).json({ error: 'Email required' });
      return;
    }
    const user = await prisma.user.upsert({
      where: { email: email },
      update: {},
      create: { id: Date.now(), email: email, username: email.split('@')[0] }
    });
    res.status(201).json({ result: 'Created', id: user.id });
  } catch (e) {
    console.error('Error creating user:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.get('/user', async (req: Request, res: Response) => {
    try {
        const { emailOrUsername } = req.query as { emailOrUsername: string };
        const users = await prisma.user.findMany({
            where: {
                OR: [
                    { email: { contains: emailOrUsername } },
                    { username: { contains: emailOrUsername } }
                ]
            }
        });
        res.status(200).json({ users });
    } catch (e) {
        res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
    }
});

app.get('/board/:id/user/:userId', async (req: Request, res: Response) => {
    try {
        const userId = Number(getParam(req.params.userId));
        const user = await prisma.user.findUnique({ where: { id: userId } });
        if (!user) {
            res.status(404).json({ error: 'User not found' });
            return;
        }
        res.status(200).json(user);
    } catch (e) {
        res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
    }
});

app.get('/board/', async (req: Request, res: Response) => {
  try {
    const boards = await prisma.board.findMany();
    res.status(200).json({
      boards: boards.map(b => ({
        ...b,
        custom: ensureJsonObject(b.custom)
      }))
    });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.get('/board/:id', async (req: Request, res: Response) => {
  try {
    const board = await prisma.board.findUnique({
      where: { id: Number(getParam(req.params.id)) },
      include: {
        users: { include: { user: true } },
        lists: {
          orderBy: { position: 'asc' },
          include: {
            cards: {
              orderBy: { position: 'asc' },
              include: { users: { include: { user: true } } }
            }
          }
        }
      }
    });

    if (!board) {
      res.status(404).json({ error: 'Board not found' });
      return;
    }

    const boardData = {
      ...board,
      custom: ensureJsonObject(board.custom),
      users: board.users.map((bu) => bu.user),
      lists: board.lists.map((list) => ({
        ...list,
        custom: ensureJsonObject(list.custom),
        cards: list.cards.map((card) => ({
          ...card,
          list_id: card.listId,
          custom: ensureJsonObject(card.custom),
          users: card.users.map((cu) => cu.user.id),
          created_at: card.created_at ? Number(card.created_at) : Date.now()
        }))
      }))
    };

    res.status(200).json(boardData);
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.post('/board/', async (req: Request, res: Response) => {
  try {
    const { title, custom } = req.body as { title: string, custom?: any };
    const board = await prisma.board.create({ data: { id: Date.now(), title, custom: ensureJsonString(custom) } });
    res.status(201).json({ result: 'Created', id: board.id });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id', async (req: Request, res: Response) => {
  try {
    const { title, custom } = req.body as { title?: string, custom?: any };
    await prisma.board.update({
      where: { id: Number(getParam(req.params.id)) },
      data: { title, custom: ensureJsonString(custom) }
    });
    res.status(200).json({ result: 'Updated' });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.delete('/board/:id', async (req: Request, res: Response) => {
  try {
    const boardId = Number(getParam(req.params.id));
    // Delete dependent data first
    await prisma.cardUser.deleteMany({ where: { card: { list: { boardId } } } });
    await prisma.boardUser.deleteMany({ where: { boardId } });
    await prisma.card.deleteMany({ where: { list: { boardId } } });
    await prisma.list.deleteMany({ where: { boardId } });
    await prisma.board.delete({ where: { id: boardId } });
    res.status(200).json({ result: 'Deleted' });
  } catch (e) {
    console.error('Error deleting board:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.post('/board/:id/list/', async (req: Request, res: Response) => {
  try {
    const boardId = Number(getParam(req.params.id));
    if (!boardId) {
        res.status(400).json({ error: 'Invalid board ID' });
        return;
    }
    const { title, position } = req.body as { title: string, position?: number };
    const list = await prisma.list.create({ data: { id: Date.now(), title, position, boardId } });
    res.status(201).json({ result: 'Created', id: list.id });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id/list/', async (req: Request, res: Response) => {
  try {
    const lists = req.body as any[];
    if (!Array.isArray(lists)) {
      res.status(400).json({ error: 'Expected an array of lists' });
      return;
    }

    for (const list of lists) {
      const data: any = {};
      if (list.title !== undefined) data.title = list.title;
      if (list.position !== undefined) data.position = list.position;
      if (list.custom !== undefined) data.custom = ensureJsonString(list.custom);

      await prisma.list.update({
        where: { id: getParam(list.id) },
        data: data
      });
    }
    res.status(200).json({ result: 'Updated' });
  } catch (e) {
    console.error('Error updating lists:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id/list/:listId', async (req: Request, res: Response) => {
  try {
    const { title, position } = req.body as { title?: string, position?: number };
    await prisma.list.update({
      where: { id: Number(getParam(req.params.listId)) },
      data: { title, position }
    });
    res.status(200).json({ result: 'Updated' });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.delete('/board/:id/list/:listId', async (req: Request, res: Response) => {
  try {
    await prisma.list.delete({ where: { id: Number(getParam(req.params.listId)) } });
    res.status(200).json({ result: 'Deleted' });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.post('/board/:id/card/', async (req: Request, res: Response) => {
  try {
    const boardId = Number(getParam(req.params.id));
    if (!boardId) {
        res.status(400).json({ error: 'Invalid board ID' });
        return;
    }
    const { title, description, listId, list_id, position, color, custom } = req.body as any;

    const listIdValue = listId !== undefined ? listId : list_id;

    if (!listIdValue) {
        res.status(400).json({ error: 'Invalid or missing list ID' });
        return;
    }

    const card = await prisma.card.create({
      data: {
        id: Date.now(),
        title,
        description,
        listId: Number(listIdValue),
        position,
        color,
        custom: ensureJsonString(custom),
        created_at: Date.now()
      }
    });
    res.status(201).json({ result: 'Created', id: card.id });
  } catch (e) {
    console.error('Error creating card:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id/card/', async (req: Request, res: Response) => {
  try {
    const cards = req.body as any[];
    if (!Array.isArray(cards)) {
      res.status(400).json({ error: 'Expected an array of cards' });
      return;
    }

    for (const card of cards) {
      const listIdValue = card.list_id !== undefined ? card.list_id : card.listId;

      const data: any = {};
      if (card.title !== undefined) data.title = card.title;
      if (card.description !== undefined) data.description = card.description;
      if (card.position !== undefined) data.position = card.position;
      if (card.color !== undefined) data.color = card.color;
      if (listIdValue !== undefined) data.listId = String(listIdValue);
      if (card.custom !== undefined) data.custom = ensureJsonString(card.custom);

      await prisma.card.update({
        where: { id: getParam(card.id) },
        data: data
      });
    }
    res.status(200).json({ result: 'Updated' });
  } catch (e) {
    console.error('Error updating cards:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id/card/:cardId', async (req: Request, res: Response) => {
  try {
    const cardId = Number(getParam(req.params.cardId));
    const { title, description, position, color, custom, list_id } = req.body as any;

    const data: any = {};
    if (title !== undefined) data.title = title;
    if (description !== undefined) data.description = description;
    if (position !== undefined) data.position = position;
    if (color !== undefined) data.color = color;
    if (custom !== undefined) data.custom = ensureJsonString(custom);
    if (list_id !== undefined) data.listId = String(list_id);

    await prisma.card.update({
      where: { id: cardId },
      data: data
    });
    res.status(200).json({ result: 'Updated' });
  } catch (e) {
    console.error('Error updating card:', e);
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.delete('/board/:id/card/:cardId', async (req: Request, res: Response) => {
  try {
    await prisma.card.delete({ where: { id: Number(getParam(req.params.cardId)) } });
    res.status(200).json({ result: 'Deleted' });
  } catch (e) {
    res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
  }
});

app.put('/board/:id/card/:cardId/users', async (req: Request, res: Response) => {
    try {
        const cardId = Number(getParam(req.params.cardId));
        const { add, remove } = req.body as { add: string[], remove: string[] };

        // Remove users
        if (remove && remove.length > 0) {
            await prisma.cardUser.deleteMany({
                where: { cardId, userId: { in: remove.map(id => BigInt(id)) } }
            });
        }

        // Add users
        if (add && add.length > 0) {
            const operations = add.map(userId =>
                prisma.cardUser.upsert({
                    where: { cardId_userId: { cardId, userId: BigInt(userId) } },
                    update: {},
                    create: { cardId, userId: BigInt(userId) }
                })
            );
            await prisma.$transaction(operations);
        }

        res.status(200).json({ result: 'Updated' });
    } catch (e) {
        console.error('Error updating card users:', e);
        res.status(500).json({ error: e instanceof Error ? e.message : String(e) });
    }
});

